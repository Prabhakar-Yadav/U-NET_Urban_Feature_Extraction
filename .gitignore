satellite_autoencoder.pth
cartosat_6_class_model.pth
pixel_teacher_mlp.pt

# Intermediate outputs
*_segmap.tif

# Reports and presentations
*.docx
*.pptx
*.pdf
report_figures/
report_and_presentation/

# Test raw data (ESRI Grid)
Test_Model/Test_Data/

